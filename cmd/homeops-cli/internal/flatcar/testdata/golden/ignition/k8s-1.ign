te.kubernetes.d /etc/sysupdate.d\nExecStart=/usr/bin/curl --fail --location --retry 6 --retry-delay 5 --retry-connrefused -o /opt/extensions/kubernetes/kubernetes-v1.36.1-x86-64.raw https://extensions.flatcar.org/extensions/kubernetes/kubernetes-v1.36.1-x86-64.raw\nExecStart=/usr/bin/curl --fail --location --retry 6 --retry-delay 5 -o /etc/sysupdate.kubernetes.d/kubernetes-v1.36.conf https://extensions.flatcar.org/extensions/kubernetes/kubernetes-v1.36.conf\nExecStart=/usr/bin/curl --fail --location --retry 6 --retry-delay 5 -o /etc/sysupdate.d/noop.conf https://extensions.flatcar.org/extensions/noop.conf\nExecStart=/usr/bin/systemd-sysext refresh\nExecStart=/usr/bin/systemctl daemon-reload\n[Install]\nWantedBy=multi-user.target\n","enabled":true,"name":"install-k8s-sysext.service"},{"enabled":true,"name":"systemd-sysext.service"},{"enabled":true,"name":"systemd-sysupdate.timer"},{"dropins":[{"contents":"[Service]\nExecStartPre=/usr/bin/sh -c 'readlink --canonicalize /etc/extensions/kubernetes.raw \u003e /tmp/kubernetes'\nExecStartPre=/usr/lib/systemd/systemd-sysupdate -C kubernetes update\nExecStartPost=/usr/bin/sh -c 'readlink --canonicalize /etc/extensions/kubernetes.raw \u003e /tmp/kubernetes-new; if ! cmp --silent /tmp/kubernetes /tmp/kubernetes-new; then touch /run/reboot-required; fi'\n","name":"kubernetes.conf"}],"name":"systemd-sysupdate.service"},{"mask":true,"name":"systemd-sysupdate-reboot.timer"},{"mask":true,"name":"systemd-sysupdate-reboot.service"}]}}