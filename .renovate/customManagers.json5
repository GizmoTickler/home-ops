{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  customDatasources: {
    // Flatcar Stable releases from the official releases feed. Used by the
    // flatcar-os SUC Plan (merge-gated OS upgrades): Renovate PRs the version
    // bump, merging it triggers the staged rollout (SUC stage + kured reboot).
    // NEVER automerge this — an OS rollout should be a deliberate merge.
    flatcar: {
      defaultRegistryUrlTemplate: "https://www.flatcar.org/releases-json/releases.json",
      format: "json",
      transformTemplates: [
        '{ "releases": $each($, function($v, $k) { $v.channel = "stable" ? { "version": $k } : undefined }) }',
      ],
    },
  },
  customManagers: [
    {
      customType: "regex",
      description: "Process annotated dependencies",
      managerFilePatterns: [
        "/\\.env(?:\\.j2)?$/",
        "/\\.sh(?:\\.j2)?$/",
        "kubernetes/**/*.yaml",
        "cmd/**/helmfile.d/**/*.yaml",
      ],
      matchStrings: [
        // # renovate: datasource=github-releases depName=foo/bar
        // foobar_version: v1.0.0
        // # renovate: datasource=docker depName=ghcr.io/foo/bar
        // FOOBAR_VERSION=v1.0.0
        "datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n.+(:\\s|=)(&\\S+\\s)?(?<currentValue>\\S+)",
      ],
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
    },
    {
      customType: "regex",
      description: "Process OCI dependencies",
      managerFilePatterns: [
        "kubernetes/**/ocirepository.yaml",
        "cmd/**/helmfile.d/**/*.yaml",
      ],
      matchStrings: [
        "oci://(?<depName>[^:]+):(?<currentValue>\\S+)",
      ],
      datasourceTemplate: "docker",
    },
  ],
}
